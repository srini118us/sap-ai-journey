{
  "name": "btp-intelligent-ops-dashboard",
  "version": "1.0.0",
  "description": "SAP BTP Intelligent Operations & FinOps Copilot",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap/cds": "^7",
    "@sap/cds-dk": "^7",
    "express": "^4",
    "hdb": "^0.19"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1"
  },
  "scripts": {
    "start": "cds-serve",
    "dev":   "cds watch",
    "build": "cds build --production"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": { "url": ":memory:" },
        "[production]": {
          "kind": "hana-cloud"
        }
      }
    },
    "features": {
      "fiori_preview": true,
      "test_mocks": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
